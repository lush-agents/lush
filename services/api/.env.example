LUSH_API_PORT=7330
LUSH_API_HOST=0.0.0.0
LUSH_APP_ORIGIN=http://localhost:1420,http://127.0.0.1:1420
DATABASE_URL=postgres://lush:lush@127.0.0.1:5432/lush
LUSH_SECRET_KEY=replace-with-random-secret
LUSH_AUTH_PASSWORD_ENABLED=true
LUSH_AUTH_JWT_ISSUER=lush-authz
LUSH_AUTH_JWT_AUDIENCE=lush-api
LUSH_AUTH_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
LUSH_AUTH_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
LUSH_AGENT_PROVIDER=fireworks
LUSH_AGENT_MODEL=glm-5.2
