{
  "name": "@lush/docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "source:codegen": "fumadocs-mdx",
    "services:codegen": "bun run scripts/generate-service-catalog.ts",
    "predev": "bun run source:codegen && bun run services:codegen && bun run --cwd ../api openapi:codegen",
    "dev": "next dev --hostname 0.0.0.0 --port 7332",
    "prebuild": "bun run source:codegen && bun run services:codegen && bun run --cwd ../api openapi:codegen",
    "build": "next build --webpack",
    "start": "next start --hostname 0.0.0.0 --port 7332",
    "pretypecheck": "bun run source:codegen && bun run services:codegen && bun run --cwd ../api openapi:codegen",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "fumadocs-core": "^15.0.0",
    "fumadocs-mdx": "^11.0.0",
    "fumadocs-ui": "^15.0.0",
    "next": "^16.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/mdx": "^2.0.13",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  }
}
