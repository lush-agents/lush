# Pin one exact Lush release for both application images.
LUSH_IMAGE_VERSION=0.1.0
LUSH_API_BIND_PORT=7330
LUSH_WEB_BIND_PORT=8080
LUSH_DATA_SUBNET=172.31.250.0/24
LUSH_EDGE_SUBNET=172.31.251.0/24
# Reserved by the optional local Caddy overlay. Keep it inside LUSH_EDGE_SUBNET.
LUSH_LOCAL_CADDY_IP=172.31.251.254

# Generate a URL-safe value with: openssl rand -hex 32
# Otherwise, URL-encode reserved characters in the DATABASE_URL copy. These
# credentials are used only on the private Compose network.
POSTGRES_DB=lush
POSTGRES_USER=lush
POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgresql://lush:replace-with-a-long-random-password@postgres:5432/lush
LUSH_DB_POOL_SIZE=10

# Generate with: openssl rand -hex 32
LUSH_SECRET_KEY=replace-with-64-random-hex-characters

# Replace all three values with the dotenv-ready output from:
# docker run --rm ghcr.io/lush-agents/lush-api:0.1.0 bun run auth:keygen
LUSH_AUTH_JWT_KEY_ID=replace-with-generated-key-id
LUSH_AUTH_JWT_PRIVATE_KEY=replace-with-generated-private-key
LUSH_AUTH_JWT_PUBLIC_KEYS=replace-with-generated-public-key-set
LUSH_AUTH_JWT_ISSUER=lush-authz
LUSH_AUTH_JWT_AUDIENCE=lush-api

LUSH_AUTH_PASSWORD_ENABLED=true
LUSH_AUTH_SIGNUP_ENABLED=true
LUSH_AUTH_PUBLIC_SIGNUP=true
LUSH_PUBLIC_APP_URL=https://lush.example.com
LUSH_APP_ORIGIN=https://lush.example.com
LUSH_REQUIRE_HTTPS=true

# SMTP is the production email adapter bundled with Lush. URL-encode SMTP
# credentials when necessary. Use smtp:// for STARTTLS or smtps:// for implicit
# TLS according to the provider's instructions.
LUSH_EMAIL_DELIVERY=smtp
LUSH_EMAIL_FROM="Lush <noreply@example.com>"
LUSH_SMTP_URL=smtps://user:password@smtp.example.com:465
LUSH_EMAIL_VERIFICATION_TTL_MS=86400000
LUSH_PASSWORD_RESET_TTL_MS=3600000

LUSH_SESSION_IP_MODE=hmac
LUSH_SESSION_TTL_MS=2592000000
LUSH_ACCESS_TOKEN_TTL_MS=300000
LUSH_REFRESH_TOKEN_GRACE_MS=60000

# A host ingress that connects through the loopback-published API port normally
# appears as this edge-network gateway. Set the exact socket peer(s) observed by
# the API for a different topology. Never trust an internet-wide range.
LUSH_TRUSTED_PROXIES=172.31.251.1/32
# Alternative for a private gateway with dynamic peer addresses. Generate at
# least 32 random characters and configure the gateway to replace the matching
# X-Lush-Proxy-Secret request header.
LUSH_TRUSTED_PROXY_SECRET=
