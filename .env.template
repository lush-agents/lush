DATABASE_URL=postgres://lush:lush@127.0.0.1:5432/lush
LUSH_SECRET_KEY=__GENERATED_LUSH_SECRET_KEY__
LUSH_AUTH_PASSWORD_ENABLED=true
LUSH_AUTH_SIGNUP_ENABLED=true
# Public signup hides whether an email already has an account. Set false only
# for private deployments where explicit duplicate-account errors are desired.
LUSH_AUTH_PUBLIC_SIGNUP=true
LUSH_EMAIL_VERIFICATION_TTL_MS=86400000
LUSH_PASSWORD_RESET_TTL_MS=3600000
LUSH_EMAIL_DELIVERY=log
LUSH_PUBLIC_APP_URL=http://localhost:5874
# SMTP delivery: set LUSH_EMAIL_DELIVERY=smtp and configure both values.
# LUSH_EMAIL_FROM=Lush <noreply@example.com>
# LUSH_SMTP_URL=smtps://user:password@smtp.example.com:465
LUSH_REFRESH_TOKEN_GRACE_MS=60000
LUSH_AUTH_JWT_ISSUER=lush-authz
LUSH_AUTH_JWT_AUDIENCE=lush-api
LUSH_AUTH_JWT_PRIVATE_KEY=__GENERATED_LUSH_AUTH_JWT_PRIVATE_KEY__
LUSH_AUTH_JWT_PUBLIC_KEY=__GENERATED_LUSH_AUTH_JWT_PUBLIC_KEY__
LUSH_API_PORT=7330
LUSH_API_HOST=0.0.0.0
# Comma-separated IP addresses or CIDR ranges for reverse proxies that rewrite
# X-Forwarded-For. Leave empty when clients connect directly to the API.
LUSH_TRUSTED_PROXIES=
LUSH_APP_ORIGIN=http://localhost:5874,http://127.0.0.1:5874,tauri://localhost,http://tauri.localhost,https://tauri.localhost
VITE_LUSH_API_BASE_URL=http://localhost:7330
