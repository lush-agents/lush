{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lush",
  "version": "0.0.0",
  "identifier": "ai.lush.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build:tauri",
    "devUrl": "http://127.0.0.1:5874",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lush",
        "label": "main",
        "width": 1200,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
