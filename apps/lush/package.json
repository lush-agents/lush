{
  "name": "@lush/app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "typecheck": "tsgo --noEmit",
    "bundle": "vite build",
    "bundle:tauri": "vite build --mode development",
    "build": "bun run typecheck && bun run bundle",
    "build:tauri": "bun run sidecar:build && bun run typecheck && bun run bundle:tauri",
    "preview": "vite preview",
    "tauri": "tauri",
    "sidecar:build": "bun ../../scripts/build-code-sidecar.ts",
    "tauri:dev": "bun run sidecar:build && tauri dev",
    "tauri:build": "tauri build --bundles app"
  },
  "dependencies": {
    "@lush/api-client": "workspace:*",
    "@lush/code": "workspace:*",
    "@pierre/diffs": "^1.2.12",
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@radix-ui/react-use-controllable-state": "^1.2.3",
    "@shadcn/react": "^0.2.1",
    "@streamdown/math": "^1.0.2",
    "ai": "^7.0.26",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "katex": "^0.16.47",
    "lucide-react": "^0.468.0",
    "motion": "^12.42.2",
    "nanoid": "^6.0.0",
    "radix-ui": "^1.6.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.0.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2.11.3",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "shadcn": "^4.13.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0"
  }
}
